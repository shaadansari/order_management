# Development — SQLite (zero config; tables auto-create on startup)
DATABASE_URL=sqlite:///./order_management.db

# Production — PostgreSQL (Render-managed). Repoint DATABASE_URL and run `alembic upgrade head`;
# no code changes needed. psycopg2-binary is the driver (psycopg2 for `postgresql://` URLs).
# DATABASE_URL=postgresql://user:password@host:5432/dbname
JWT_SECRET_KEY=change-me-in-production-please
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
APP_ENV=development
API_VERSION=v1
REDIS_URL=redis://localhost:6379/0
